{
  "openapi": "3.0.0",
  "info": {
    "title": "Personal Website API",
    "version": "1.0.0",
    "description": "API documentation for the Personal Website project."
  },
  "servers": [
    {
      "url": "http://localhost:3000/api",
      "description": "Local server"
    }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "summary": "Login",
        "description": "Authenticate and get a JWT token.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                },
                "required": ["email", "password"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": { "type": "string" },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          },
          "400": { "description": "Invalid input" },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/auth/me": {
      "get": {
        "summary": "Get current user",
        "description": "Retrieve the authenticated user's information.",
        "responses": {
          "200": {
            "description": "User information",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "user": { "type": "object" }
                  }
                }
              }
            }
          },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/cv/upload": {
      "post": {
        "summary": "Upload CV",
        "description": "Upload a CV file (protected route).",
        "responses": {
          "200": { "description": "CV uploaded successfully" },
          "400": { "description": "No file uploaded" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/cv/download": {
      "get": {
        "summary": "Download CV",
        "description": "Download the uploaded CV file.",
        "responses": {
          "200": {
            "description": "CV file",
            "content": {
              "application/pdf": {}
            }
          },
          "404": { "description": "CV not found" }
        }
      }
    },
    "/projects": {
      "get": {
        "summary": "Get all projects",
        "description": "Retrieve all projects.",
        "responses": {
          "200": {
            "description": "List of projects",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "projects": {
                      "type": "array",
                      "items": { "type": "object" }
                    },
                    "total": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
